rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isFirstAdmin() {
      return isAuthenticated() && 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidAdminData() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'role', 'createdAt', 'updatedAt']) &&
             data.role == 'admin' &&
             data.email is string &&
             data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$') &&
             data.createdAt is string &&
             data.updatedAt is string;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Allow read if user is authenticated and accessing their own document or is admin
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow create if:
      // 1. User is creating their own document for the first time (first admin)
      // 2. User is an admin creating a new admin
      allow create: if isAuthenticated() && 
                   ((request.auth.uid == userId && isFirstAdmin()) || 
                    (isAdmin() && isValidAdminData()));
      
      // Allow updates only for admin users
      allow update: if isAdmin() && isValidAdminData();
      
      // Allow delete only for admin users
      allow delete: if isAdmin();
    }

    // Rest of your existing rules...
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /extra_charges/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_rates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 